<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Employee Management</title>

  <!-- Bootstrap CSS from CDN - handles all the responsive layout and components -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <!-- Bootstrap Icons for the small icons in buttons and navbar -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    rel="stylesheet"
  />
</head>
<body class="bg-light">

  <!-- navbar at the top - clicking the brand goes back to the list -->
  <nav class="navbar navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/employees">
        <i class="bi bi-people-fill me-2"></i>Employee Manager
      </a>
    </div>
  </nav>

  <div class="container py-4">

    <!-- page header with the Add button on the right -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0 fw-bold">Employees</h2>
      <a href="/employees/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Employee
      </a>
    </div>

    <!-- show a message if there are no employees yet -->
    <% if (employees.length === 0) { %>
      <div class="alert alert-info text-center" role="alert">
        <i class="bi bi-info-circle me-1"></i>
        No employees found. <a href="/employees/new" class="alert-link">Add the first one.</a>
      </div>

    <% } else { %>

      <!-- employee table wrapped in a card for cleaner look -->
      <div class="card shadow-sm">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-primary">
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Department</th>
                  <th>Position</th>
                  <th class="text-end">Salary</th>
                  <th class="text-center">Actions</th>
                </tr>
              </thead>
              <tbody>
                <!-- loop through each employee coming from the route -->
                <% employees.forEach((employee, index) => { %>
                  <tr>
                    <td class="text-muted"><%= index + 1 %></td>
                    <td class="fw-semibold">
                      <%= employee.firstName %> <%= employee.lastName %>
                    </td>
                    <td><%= employee.email %></td>
                    <td>
                      <!-- badge just to make department stand out a bit -->
                      <span class="badge bg-secondary"><%= employee.department %></span>
                    </td>
                    <td><%= employee.position %></td>
                    <td class="text-end">
                      <!-- toLocaleString formats the number with commas e.g. $75,000 -->
                      $<%= employee.salary.toLocaleString("en-US") %>
                    </td>
                    <td class="text-center">

                      <!-- edit button - goes to the edit form for this employee -->
                      <a
                        href="/employees/<%= employee._id %>/edit"
                        class="btn btn-sm btn-outline-primary me-1"
                        title="Edit"
                      >
                        <i class="bi bi-pencil"></i>
                      </a>

                      <!-- delete button - uses a form with POST + _method=DELETE
                           because HTML forms don't support DELETE natively -->
                      <form
                        action="/employees/<%= employee._id %>?_method=DELETE"
                        method="POST"
                        class="d-inline"
                        onsubmit="return confirm('Delete <%= employee.firstName %> <%= employee.lastName %>?')"
                      >
                        <button
                          type="submit"
                          class="btn btn-sm btn-outline-danger"
                          title="Delete"
                        >
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>

                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- footer shows total count -->
        <div class="card-footer text-muted small">
          Total: <%= employees.length %> employee<%= employees.length !== 1 ? 's' : '' %>
        </div>
      </div>

    <% } %>
  </div>

  <!-- Bootstrap JS needed for interactive components -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
